#!/bin/sh
set -eu

root="$(git rev-parse --show-toplevel)"
head_sha="$(git rev-parse HEAD)"
approval_file="$root/.git/PUSH_APPROVED"
scanner="${PRE_PUBLISH_SAFETY_SCRIPT:-$HOME/.agents/skills/pre-publish-safety/scripts/pre_publish_safety.py}"

if [ ! -f "$approval_file" ] || [ "$(tr -d '\r\n' < "$approval_file")" != "$head_sha" ]; then
  echo "BLOCKED: explicit push approval for the current commit is missing." >&2
  echo "After the user reviews the release manifest and explicitly approves this push," >&2
  echo "write the current HEAD SHA to .git/PUSH_APPROVED and retry." >&2
  exit 1
fi

if [ ! -f "$scanner" ]; then
  echo "BLOCKED: pre-publish safety scanner was not found." >&2
  echo "Set PRE_PUBLISH_SAFETY_SCRIPT to the scanner path and retry." >&2
  exit 1
fi

cd "$root"
npm run verify

report_base="${TMPDIR:-/tmp}/job-search-operations-prepush"
python3 "$scanner" "$root" \
  --run-external \
  --md-out "${report_base}.md" \
  --json-out "${report_base}.json" \
  --fail-on-review

rm -f "$approval_file"
echo "Pre-push safety gate passed for $head_sha."
